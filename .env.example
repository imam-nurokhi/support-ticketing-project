# Environment variables for Resolv Support Ticketing
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=file:./prisma/dev.db

# Email (SMTP) — optional, emails will be skipped if not configured
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Resolv Support <no-reply@yourdomain.com>

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# File upload directory (optional, defaults to ./uploads)
# UPLOAD_DIR=/data/uploads
